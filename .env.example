# =============================================================
# Ollama Structured API — Configuration
# Copy this file to .env and adjust as needed
# =============================================================

# ----- Port Configuration -----
API_PORT=8000
OLLAMA_PORT=11434

# ----- Ollama Connection -----
# Used when running app.py directly (without Docker)
OLLAMA_BASE_URL=http://localhost:11434

# ----- Model Configuration -----
# Default model to pull on first Docker startup
DEFAULT_MODEL=qwen3.5:9b
